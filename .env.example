# Copy to .env and fill in values
HF_TOKEN=hf_your_token_here
VAST_AI_IP=your.vast.ai.ip
VAST_AI_PORT=22
VAST_AI_USER=root
HF_HUB_MODEL=your-username/msmarco-bi-encoder
VLLM_MODEL=TheBloke/Mistral-7B-Instruct-v0.2-AWQ
# Dense teacher embedding server (used by make start-vllm-teacher for Phase 2 mining)
# Set to the model you want to use as the hard negative mining teacher.
# Cannot run alongside VLLM_MODEL on a 16 GB GPU — use one at a time.
TEACHER_MODEL=intfloat/e5-mistral-7b-instruct
